# ─────────────────────────────────────────────────────────────────────────────
# Video Scout — Environment Variables
# Copy this file to .env.local for local dev,
# or paste these keys into Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# OPTION 1 (Recommended): TikHub.io
# → Free signup at https://tikhub.io
# → Dashboard → API Keys → Create Key
# → ~$0.001 per scrape run, free credits on signup
TIKHUB_API_KEY=

# OPTION 2 (Fallback): Apify
# → Free signup at https://apify.com
# → $5 free credits, no credit card needed
APIFY_API_KEY=

# Leave both empty → runs in DEMO MODE (mock data, no real scraping)
